{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nameless-academy.local/schema/question-bank.schema.json",
  "title": "Nameless Academy runtime question bank",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "subject", "mode", "levels"],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "subject": {
      "enum": ["math", "english", "science"]
    },
    "mode": {
      "enum": ["normal", "hard"]
    },
    "levels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/level"
      }
    }
  },
  "$defs": {
    "localizedText": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["zh", "en"],
          "properties": {
            "zh": {
              "type": "string",
              "minLength": 1
            },
            "en": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    },
    "level": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "name", "questions"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "$ref": "#/$defs/localizedText"
        },
        "questions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/question"
          }
        }
      }
    },
    "question": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "type", "question", "answer"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "enum": ["number", "meaning", "synonym", "grammar", "reading", "mc"]
        },
        "question": {
          "$ref": "#/$defs/localizedText"
        },
        "passage": {
          "$ref": "#/$defs/localizedText"
        },
        "options": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/localizedText"
          }
        },
        "answer": {
          "type": "number"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "number"
              }
            }
          },
          "then": {},
          "else": {
            "required": ["options"]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "reading"
              }
            }
          },
          "then": {
            "required": ["passage"]
          }
        }
      ]
    }
  }
}
